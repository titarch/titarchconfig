{
  "env": {
    "PATH": "$(PATH):$(HOME)/.local/bin"
  },
  "apps": [
    {
      "name": "Desktop (current layout)",
      "image-path": "desktop.png"
    },
    {
      "name": "Desktop (laptop 1080p)",
      "image-path": "desktop.png",
      "prep-cmd": [
        {
          "do": "/home/bparsy/.local/bin/stream on laptop",
          "undo": ""
        }
      ]
    },
    {
      "name": "Desktop (thinkpad 1920x1200)",
      "image-path": "desktop.png",
      "prep-cmd": [
        {
          "do": "/home/bparsy/.local/bin/stream on thinkpad",
          "undo": ""
        }
      ]
    },
    {
      "name": "Desktop (QHD)",
      "image-path": "desktop.png",
      "prep-cmd": [
        {
          "do": "/home/bparsy/.local/bin/stream on qhd",
          "undo": ""
        }
      ]
    },
    {
      "name": "Desktop (ultrawide)",
      "image-path": "desktop.png",
      "prep-cmd": [
        {
          "do": "/home/bparsy/.local/bin/stream on ultrawide",
          "undo": ""
        }
      ]
    },
    {
      "name": "Desktop (4K TV)",
      "image-path": "desktop.png",
      "prep-cmd": [
        {
          "do": "/home/bparsy/.local/bin/stream on tv4k",
          "undo": ""
        }
      ]
    },
    {
      "name": "Steam Big Picture",
      "detached": [
        "setsid steam steam://open/bigpicture"
      ],
      "prep-cmd": [
        {
          "do": "/home/bparsy/.local/bin/stream on default",
          "undo": ""
        },
        {
          "do": "",
          "undo": "setsid steam steam://close/bigpicture"
        }
      ],
      "image-path": "steam.png"
    }
  ]
}