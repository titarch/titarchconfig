# Deployed to /etc/udev/rules.d/61-sunshine-uinput.rules
# Sunshine (user service) needs /dev/uinput (virtual keyboard/mouse) and
# /dev/uhid (controller emulation). The packaged 60-sunshine.rules already
# sets uinput to root:input 0660; this rule does the same for uhid, and
# bparsy is in the "input" group.
# IMPORTANT: do NOT set OWNER=bparsy on these nodes — bluetoothd runs with
# a capability bounding set lacking cap_dac_override, so it NEEDS root
# ownership of /dev/uhid to create Bluetooth HID input devices (BT mouse
# broke with "input-hog profile accept failed" otherwise).
KERNEL=="uhid", GROUP="input", MODE="0660"
