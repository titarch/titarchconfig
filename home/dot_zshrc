# --- oh-my-zsh ---
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME=""            # prompt is starship (initialised at the bottom)
# tail order matters: fzf-tab after fzf (rebinds Tab), the widget-wrappers
# zsh-autosuggestions and zsh-syntax-highlighting last
plugins=(cp git docker pip python sudo systemd autoswitch_virtualenv zsh-completions kubectl minikube history terraform terragrunt zoxide uv deno fzf fzf-tab zsh-autosuggestions zsh-syntax-highlighting)
source $ZSH/oh-my-zsh.sh

# --- history ---
HISTFILE=~/.zsh_history
HISTSIZE=999999999          # keep everything, never trim (see zsh-history-backup)
SAVEHIST=$HISTSIZE

# --- environment ---
export EDITOR='nvim'
export PATH="$PATH:$HOME/SDKs/az/bin:/opt/cuda/bin:$HOME/.local/bin:$HOME/.cargo/bin:$HOME/.local/share/gem/ruby/3.0.0/bin"
export CUDA_HOME=/opt/cuda
export PGDATA="$HOME/postgres_data"
export PGHOST="/tmp"
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# --- completion ---
# ask make for the full target DB (handles `include ...`), cached
zstyle ':completion:*:*:make:*' call-command true
zstyle ':completion:*:*:make:*' use-cache on
zstyle ':completion:*:*:make:*' cache-path ~/.cache/zsh/make
zstyle ':completion:*:*:docker:*' option-stacking yes
zstyle ':completion:*:*:docker-*:*' option-stacking yes
kitty + complete setup zsh | source /dev/stdin
# fzf-tab: switch result groups with , / . and preview dirs on cd
zstyle ':fzf-tab:*' switch-group ',' '.'
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza -1 --color=always $realpath 2>/dev/null || ls -1 $realpath'

# --- functions ---
makewatch() {
    [[ -n "$1" ]] && texfile="$1" || texfile=(*.tex(N[1]))
    echo "Selected file: $texfile"
    while true; do inotifywait -e modify "$texfile"; date; make; done
}

acenv() {
    [[ "$#" -ne 1 ]] && echo "Usage: acenv <env>" && return 1
    [[ -f "$1" ]] && source "$1" && return 0
    [[ -f "envs/$1.env" ]] && source "envs/$1.env" && return 0
    export REDIS_PORT=6380
}

# kill + remove all containers
dcka() {
    active_containers=$(docker ps -q)
    if [[ -n "$active_containers" ]]; then
        docker kill `docker ps -q`
    else
        echo "No active containers"
    fi
    exited_containers=$(docker ps -aq)
    if [[ -n "$exited_containers" ]]; then
        docker rm `docker ps -aq`
    else
        echo "No exited containers"
    fi
}

bi() {
    BRANCH_INDEX=$(git_current_branch | cut -d'-' -f1)
    printf "-- #${BRANCH_INDEX}"
}

# git rebase savepoints: checkpoint branch / snapshot / restore / list
grb-mark() {
  local name="${1:-$(date +%Y%m%d-%H%M%S)}"
  git branch "checkpoint/$name"
}

grb-save() {
  local name="${1:-$(date +%Y%m%d-%H%M%S)}"
  local dir=".git/rebase-saves/$name"
  mkdir -p "$dir"

  cp .git/index "$dir/index"

  if [ -d .git/rebase-merge ]; then
    cp -R .git/rebase-merge "$dir/rebase-merge"
    echo "rebase-merge" > "$dir/mode"
  elif [ -d .git/rebase-apply ]; then
    cp -R .git/rebase-apply "$dir/rebase-apply"
    echo "rebase-apply" > "$dir/mode"
  else
    echo "No rebase in progress" >&2
    return 1
  fi

  git rev-parse HEAD > "$dir/head"
  git diff > "$dir/worktree.patch"
  git diff --cached > "$dir/index.patch"

  echo "Saved rebase state to $dir"
}

grb-load() {
  local name="$1"
  local dir=".git/rebase-saves/$name"

  [ -d "$dir" ] || { echo "Unknown savepoint: $name" >&2; return 1; }

  cp "$dir/index" .git/index

  rm -rf .git/rebase-merge .git/rebase-apply
  if [ "$(cat "$dir/mode")" = "rebase-merge" ]; then
    cp -R "$dir/rebase-merge" .git/rebase-merge
  else
    cp -R "$dir/rebase-apply" .git/rebase-apply
  fi

  git checkout -- .
  echo "Restored rebase state from $dir"
}

grb-list() {
  ls -1 .git/rebase-saves 2>/dev/null || true
}

# --- aliases ---
alias rm='rm -I'
alias grep='grep --color -n'
alias vim='nvim'          # real vim still reachable via \vim or `command vim`
alias p='vim -p'
alias f='find -name'
alias watcha='watch -n 1 '
alias goodbye='systemctl poweroff'
alias x='start-hyprland'
alias setclip='wl-copy'
alias getclip='wl-paste'
alias eb='vim ~/.zshrc'
alias sb='source ~/.zshrc'
alias ebh='vim ~/.zsh_history'
alias '??'="$HOME/Scripts/suggest.sh"
alias jn='jupyter notebook'
alias psh='pipenv shell'
alias lsgpu='nvidia-smi'
alias pgrun='postgres -k "$PGHOST"'
# C/C++ build
alias ccw='g++ -Wall -Werror -Wextra -pedantic -std=c++20'
alias ccgdb='ccw -g'
alias ccasan='ccgdb -fsanitize=address -lasan'
alias makj='make -j8'
alias nj='ninja'
alias cnj='cmake -G "Ninja"'
alias cnjd='cnj -DCMAKE_BUILD_TYPE=Debug'
alias cnjr='cnj -DCMAKE_BUILD_TYPE=Release'
# kubectl finished-pod cleanup
alias kdelps='kdelp --field-selector=status.phase==Succeeded'
alias kdelpf='kdelp --field-selector=status.phase==Failed'
alias kdelpa='kdelps && kdelpf'
# eza for ls/ll/la (icons/git status only in a tty)
if command -v eza >/dev/null; then
    alias ls='eza --group-directories-first'
    alias ll='eza -lh --group-directories-first --git --icons=auto'
    alias la='eza -lah --group-directories-first --git --icons=auto'
fi

# --- tool integrations ---
[ -f "$HOME/SDKs/az/lib/az.completion" ] && . "$HOME/SDKs/az/lib/az.completion"
[ -f "$HOME/SDKs/google-cloud-sdk/path.zsh.inc" ] && . "$HOME/SDKs/google-cloud-sdk/path.zsh.inc"
[ -f "$HOME/SDKs/google-cloud-sdk/completion.zsh.inc" ] && . "$HOME/SDKs/google-cloud-sdk/completion.zsh.inc"
[ -f "$HOME/.wasmedge/env" ] && . "$HOME/.wasmedge/env"
[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"
command -v direnv >/dev/null && eval "$(direnv hook zsh)"
command -v zoxide >/dev/null && eval "$(zoxide init zsh)"
# atuin owns ctrl-r; load last so its ^R wins over fzf. up-arrow stays default
command -v atuin >/dev/null && eval "$(atuin init zsh --disable-up-arrow)"
# starship prompt (replaces the omz theme; reads ~/.config/starship.toml)
command -v starship >/dev/null && eval "$(starship init zsh)"

# --- work (company kube/az/aws; gated by features.work, see .chezmoiignore) ---
[[ -r ~/.config/zsh/work.zsh ]] && source ~/.config/zsh/work.zsh
