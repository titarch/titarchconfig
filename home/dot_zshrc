makewatch() {
    [[ -n "$1" ]] && texfile="$1" || texfile=(*.tex(N[1]))
    echo "Selected file: $texfile"
    while true; do inotifywait -e modify "$texfile"; date; make; done
}

acenv() {
    [[ "$#" -ne 1 ]] && echo "Usage: acenv <env>" && return 1
    [[ -f "$1" ]] && source "$1" && return 0
    [[ -f "envs/$1.env" ]] && source "envs/$1.env" && return 0
    export REDIS_PORT=6380
}

dcka() {
    active_containers=$(docker ps -q)
    if [[ -n "$active_containers" ]]; then
        docker kill `docker ps -q`
    else
        echo "No active containers"
    fi
    exited_containers=$(docker ps -aq)
    if [[ -n "$exited_containers" ]]; then
        docker rm `docker ps -aq`
    else
        echo "No exited containers"
    fi
}

bi() {
    BRANCH_INDEX=$(git_current_branch | cut -d'-' -f1)
    printf "-- #${BRANCH_INDEX}"
}

grb-mark() {
  local name="${1:-$(date +%Y%m%d-%H%M%S)}"
  git branch "checkpoint/$name"
}

grb-save() {
  local name="${1:-$(date +%Y%m%d-%H%M%S)}"
  local dir=".git/rebase-saves/$name"
  mkdir -p "$dir"

  cp .git/index "$dir/index"

  if [ -d .git/rebase-merge ]; then
    cp -R .git/rebase-merge "$dir/rebase-merge"
    echo "rebase-merge" > "$dir/mode"
  elif [ -d .git/rebase-apply ]; then
    cp -R .git/rebase-apply "$dir/rebase-apply"
    echo "rebase-apply" > "$dir/mode"
  else
    echo "No rebase in progress" >&2
    return 1
  fi

  git rev-parse HEAD > "$dir/head"
  git diff > "$dir/worktree.patch"
  git diff --cached > "$dir/index.patch"

  echo "Saved rebase state to $dir"
}

grb-load() {
  local name="$1"
  local dir=".git/rebase-saves/$name"

  [ -d "$dir" ] || { echo "Unknown savepoint: $name" >&2; return 1; }

  cp "$dir/index" .git/index

  rm -rf .git/rebase-merge .git/rebase-apply
  if [ "$(cat "$dir/mode")" = "rebase-merge" ]; then
    cp -R "$dir/rebase-merge" .git/rebase-merge
  else
    cp -R "$dir/rebase-apply" .git/rebase-apply
  fi

  git checkout -- .
  echo "Restored rebase state from $dir"
}

grb-list() {
  ls -1 .git/rebase-saves 2>/dev/null || true
}

