# Hyprland + DankMaterialShell, i3 keybind port
{{- $host := index .hosts .chezmoi.hostname }}

# monitors
{{- if $host }}
{{- range $host.monitors }}
monitor = {{ .wayland }}, {{ .mode }}, {{ .pos }}, 1
{{- end }}
{{- else }}
monitor = , preferred, auto, 1
{{- end }}
{{- if .features.streaming }}
# owned by the stream script, wins over rules above on reload
source = ~/.config/hypr/monitors-runtime.conf
{{- end }}

# env
{{- if .features.nvidia }}
env = LIBVA_DRIVER_NAME,nvidia
env = __GLX_VENDOR_LIBRARY_NAME,nvidia
env = NVD_BACKEND,direct
{{- end }}
env = ELECTRON_OZONE_PLATFORM_HINT,auto
env = GTK_THEME,Dracula
env = QT_QPA_PLATFORMTHEME,qt6ct
# fcitx5: GTK apps use wayland text-input directly, no GTK_IM_MODULE
env = QT_IM_MODULE,fcitx
env = XMODIFIERS,@im=fcitx
env = SDL_IM_MODULE,fcitx
# kitty has no wayland text-input, it does IME via the ibus protocol
env = GLFW_IM_MODULE,ibus

# autostart
exec-once = systemctl --user import-environment WAYLAND_DISPLAY DISPLAY HYPRLAND_INSTANCE_SIGNATURE && dbus-update-activation-environment --systemd WAYLAND_DISPLAY DISPLAY XDG_CURRENT_DESKTOP
exec-once = dms run
exec-once = wl-paste --type text --watch cliphist store
exec-once = wl-paste --type image --watch cliphist store
exec-once = fcitx5 -d
# random cursor accent at login, drifts to the next every 20min
exec-once = ~/.local/bin/cursor-drift daemon
{{- if .features.streaming }}
exec-once = ~/.local/bin/stream init-virt
{{- end }}
# lock on boot only when greetd auto-logs-in (else the greeter already asked)
exec-once = sh -c 'grep -q "^\[initial_session\]" /etc/greetd/config.toml 2>/dev/null || exit 0; for i in $(seq 1 60); do dms ipc call lock lock >/dev/null 2>&1 && exit; sleep 0.5; done'

input {
    kb_layout = fr
    kb_variant = us
    kb_options = compose:{{ .composeKey }}{{ if .capsSwapEscape }},caps:swapescape{{ end }}
    follow_mouse = 1
}
{{- if .features.streaming }}
# sunshine virtual kbd bypasses caps2esc; options override, not merge
device {
    name = keyboard-passthrough
    kb_layout = fr
    kb_variant = us
    kb_options = compose:{{ .composeKey }},caps:swapescape
}
{{- end }}

general {
    gaps_in = 4
    gaps_out = 8
    border_size = 2
    col.active_border = rgb(a184d6) rgb(d673ab) 45deg
    col.inactive_border = rgb(44475a)
    layout = dwindle
}
decoration {
    rounding = 8
    blur {
        enabled = {{ .features.fancyFx }}
        size = 6
        passes = 3
        popups = true
    }
    shadow {
        enabled = {{ .features.fancyFx }}
        range = 18
        render_power = 3
        color = rgba(1e2029b0)
    }
}
dwindle {
    preserve_split = true
}
group {
    col.border_active = rgb(ff79c6) rgb(bd93f9) 45deg
    col.border_inactive = rgb(44475a)
    groupbar {
        col.active = rgb(503d80)
        col.inactive = rgb(282a36)
        text_color = rgb(f8f8f2)
    }
}
misc {
    disable_hyprland_logo = true
}

# durations in 100ms units
animations {
    enabled = true
    bezier = quick, 0.23, 1, 0.32, 1
    animation = global, 1, 2.5, quick
    animation = windows, 1, 1.5, quick, popin 85%
    animation = windowsOut, 1, 1.2, quick, popin 85%
    animation = fade, 1, 1.5, quick
    animation = layers, 1, 1.2, quick
    animation = workspaces, 1, 2, quick, slide
    animation = border, 1, 2, quick
{{- if .features.fancyFx }}
    animation = borderangle, 1, 50, linear, loop
{{- end }}
}

$mod = SUPER
$alt = ALT

# apps
bind = $mod, Return, exec, kitty
bind = $mod SHIFT, Q, killactive
bind = $mod, D, exec, dms ipc call spotlight toggle
bind = $mod, slash, exec, dms ipc call hypr toggleOverview
bind = $mod, F1, exec, dms ipc call keybinds toggle hyprland
bind = $mod SHIFT, V, exec, dms ipc call clipboard toggle
bind = $mod CTRL, L, exec, dms ipc call lock lock
bind = $mod CTRL SHIFT, L, exec, systemctl suspend
bind = $mod CTRL SHIFT, P, exec, systemctl hibernate
bind = $mod CTRL SHIFT, A, exec, systemctl poweroff
bind = $mod CTRL SHIFT, R, exec, reboot
bind = $mod CTRL, J, exec, jetbrains-toolbox
# region select then annotate/copy/save (dms screenshot mode is niri-only)
bind = $mod, F12, exec, sh -c 'grim -g "$(slurp)" - | satty --filename - --output-filename ~/Pictures/Screenshots/shot-$(date +%Y%m%d-%H%M%S).png --early-exit --copy-command wl-copy'
bind = $mod, grave, exec, rofimoji
bind = $mod, Insert, exec, notify-send "Clipboard" "$(wl-paste)"
bind = $mod, Pause, exec, sh -c 'qrencode -s 50 -o /tmp/qr.png "$(wl-paste)" && feh --auto-zoom --fullscreen /tmp/qr.png || notify-send "QR Code Failure" "Error code $?"'
{{- if .features.streaming }}
bind = $mod SHIFT, S, exec, ~/.local/bin/stream toggle
{{- end }}
# toggle idle inhibition (mod+P)
bind = $mod, P, exec, ~/.local/bin/presence toggle
bind = $mod, N, exec, dms ipc call notepad toggle
# dock toggle disabled, dms 1.5.2 ignores dockPosition and shoves windows
# from the top edge; retry after a dms update
# bind = $mod, B, exec, dms ipc call dock toggle
bind = $mod, Escape, exec, dms ipc call processlist toggle
bind = CTRL, grave, exec, dms ipc call notifications toggle
bind = CTRL, space, exec, dms ipc call notifications dismissAllPopups
bind = CTRL SHIFT, space, exec, dms ipc call notifications clearAll
bind = $mod SHIFT, E, exec, dms ipc call powermenu toggle

# focus / move
bind = $mod, J, movefocus, l
bind = $mod, K, movefocus, d
bind = $mod, L, movefocus, u
bind = $mod, semicolon, movefocus, r
bind = $mod, left, movefocus, l
bind = $mod, down, movefocus, d
bind = $mod, up, movefocus, u
bind = $mod, right, movefocus, r
# movewindow variant that joins a group when pushed into one
bind = $mod SHIFT, J, movewindoworgroup, l
bind = $mod SHIFT, K, movewindoworgroup, d
bind = $mod SHIFT, L, movewindoworgroup, u
bind = $mod SHIFT, semicolon, movewindoworgroup, r
bind = $mod SHIFT, left, movewindoworgroup, l
bind = $mod SHIFT, down, movewindoworgroup, d
bind = $mod SHIFT, up, movewindoworgroup, u
bind = $mod SHIFT, right, movewindoworgroup, r

# splits, group = i3 tabbed
bind = $mod, H, layoutmsg, preselect r
bind = $mod, V, layoutmsg, preselect d
bind = $mod, F, fullscreen, 0
bind = $mod, W, togglegroup
bind = $mod, TAB, changegroupactive, f
bind = $mod SHIFT, TAB, changegroupactive, b
bind = $mod, E, layoutmsg, togglesplit
bind = $mod SHIFT, space, togglefloating

# workspaces 1-12, primed set 13-24 on $mod+$alt; only one example of each
# pattern here, the other 44 live in the sourced file to keep the DMS
# cheatsheet readable
bind = $mod, 1, workspace, 1
bind = $mod $alt, 1, workspace, 13
bind = $mod SHIFT, 1, movetoworkspace, 1
bind = $mod SHIFT $alt, 1, movetoworkspace, 13

source = ~/.config/hypr/binds-workspaces.conf

bind = $mod CTRL, right, movecurrentworkspacetomonitor, r
bind = $mod CTRL, left, movecurrentworkspacetomonitor, l

bind = $mod SHIFT, C, exec, hyprctl reload
bind = $mod SHIFT, R, exec, hyprctl reload

# resize submap
bind = $mod, R, submap, resize
submap = resize
binde = , J, resizeactive, -40 0
binde = , K, resizeactive, 0 40
binde = , L, resizeactive, 0 -40
binde = , semicolon, resizeactive, 40 0
binde = , left, resizeactive, -40 0
binde = , down, resizeactive, 0 40
binde = , up, resizeactive, 0 -40
binde = , right, resizeactive, 40 0
bind = , Return, submap, reset
bind = , escape, submap, reset
bind = $mod, R, submap, reset
submap = reset

bindm = $mod, mouse:272, movewindow
bindm = $mod, mouse:273, resizewindow

# media / volume / brightness
bindl = , XF86AudioRaiseVolume, exec, pactl set-sink-volume @DEFAULT_SINK@ +5%
bindl = , XF86AudioLowerVolume, exec, pactl set-sink-volume @DEFAULT_SINK@ -5%
bindl = , XF86AudioMute, exec, pactl set-sink-mute @DEFAULT_SINK@ toggle
bindl = , XF86MonBrightnessUp, exec, dms ipc call brightness increment 5 ""
bindl = , XF86MonBrightnessDown, exec, dms ipc call brightness decrement 5 ""
bindl = , XF86AudioPlay, exec, playerctl play-pause
bindl = , XF86AudioPause, exec, playerctl pause
bindl = , XF86AudioNext, exec, playerctl next
bindl = , XF86AudioPrev, exec, playerctl previous
bind = $mod $alt, down, exec, playerctl play-pause
bind = $mod $alt, left, exec, playerctl previous
bind = $mod $alt, right, exec, playerctl next

# window rules
windowrule = float on, match:title ^(float-.*)
windowrule = float on, match:title ^(sfml-.*)
