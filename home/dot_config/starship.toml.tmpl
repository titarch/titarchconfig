# starship prompt — colors from .chezmoidata.toml [theme]
"$schema" = 'https://starship.rs/config-schema.json'
add_newline = false

# left: dir + git + venv + direnv, then the prompt char on its own line
format = "$directory$git_branch$git_status$git_state$python$direnv$line_break$status$character"
# right: how long the last command took, kube context, prod marker
right_format = "$cmd_duration$kubernetes${custom.prod}"

[directory]
style = "bold {{ .theme.cyan }}"
truncation_length = 3
truncate_to_repo = false

[git_branch]
symbol = " "
style = "bold {{ .theme.purple }}"

[git_status]
style = "{{ .theme.red }}"

[git_state]
style = "bold {{ .theme.yellow }}"

[python]
symbol = "🐍 "
style = "{{ .theme.green }}"
format = '[${symbol}${virtualenv}]($style) '

# direnv loaded = a work project's pinned (nix) tools are active
[direnv]
disabled = false
symbol = "❄ "
style = "{{ .theme.cyan }}"
format = '[$symbol]($style)'

[cmd_duration]
min_time = 2000
format = '[⏱ $duration]($style) '
style = "{{ .theme.yellow }}"

[kubernetes]
disabled = false
symbol = "☸ "
style = "bold {{ .theme.pink }}"
format = '[$symbol$context]($style) '

# red PROD marker when kprod has touched ~/.prod (ktest/kstag/kdemo clear it)
[custom.prod]
when = 'test -f "$HOME/.prod"'
command = 'echo PROD'
format = '[ $output ](bold {{ .theme.bg }} bg:{{ .theme.red }})'

[status]
disabled = false
symbol = "✘ "
format = '[$symbol$status]($style) '
style = "bold {{ .theme.red }}"

[character]
success_symbol = "[❯](bold {{ .theme.green }})"
error_symbol = "[❯](bold {{ .theme.red }})"
