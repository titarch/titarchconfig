#!/bin/sh
# phone profile hook: touch-friendly layout on a dedicated workspace
if [ -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" ] && hyprctl monitors >/dev/null 2>&1; then
    hyprctl dispatch workspace name:phone >/dev/null
    if [ "$(hyprctl -j workspaces | jq '[.[] | select(.name=="phone")] | first.windows // 0')" = "0" ]; then
        hyprctl dispatch exec firefox >/dev/null
    fi
else
    # tabbed = tappable titlebars
    i3-msg 'workspace phone' >/dev/null
    i3-msg 'layout tabbed' >/dev/null
    if [ "$(i3-msg -t get_tree | jq '[recurse(.nodes[]?) | select(.type=="workspace" and .name=="phone") | .nodes | length] | first')" = "0" ]; then
        i3-msg 'exec firefox' >/dev/null
    fi
fi
