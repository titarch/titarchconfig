#!/usr/bin/env bash
# idempotent dms setup, run from inside a session: merges defaults.json into
# settings.json (keys that must match on all machines live there), bottom bar,
# netspeed first, idle inhibitor, battery when one exists; restarts the shell
set -u
command -v dms >/dev/null || { echo "dms not installed" >&2; exit 1; }
dms ipc call plugins enable netspeed >/dev/null 2>&1
# setPosition also makes dms persist barConfigs into settings.json
dms ipc call bar setPosition id default bottom >/dev/null 2>&1
sleep 1
dms kill >/dev/null 2>&1
sleep 2
# transparency only reads well with blur behind it, so gate on fancyFx
export BAR_ALPHA={{ if .features.fancyFx }}0.72{{ else }}1.0{{ end }}
export POPUP_ALPHA={{ if .features.fancyFx }}0.75{{ else }}1.0{{ end }}
python3 - <<'EOF'
import json, glob, os
base = os.path.expanduser("~/.config/DankMaterialShell")
p = os.path.join(base, "settings.json")
d = json.load(open(p)) if os.path.exists(p) else {}
d.update(json.load(open(os.path.join(base, "defaults.json"))))
d["popupTransparency"] = float(os.environ["POPUP_ALPHA"])
for c in d.get("barConfigs", []):
    c["position"] = 1
    c["transparency"] = float(os.environ["BAR_ALPHA"])
    # bar background scroll misfires with hovered vs focused screen (dms
    # 1.5.2), widget scroll still works; retry after dms updates
    c["scrollEnabled"] = False
    # canonical right side: net + system-monitor cluster (cpu/gpu/mem/disk
    # grouped), then status/action icons. battery only on machines with one
    import shutil
    gpu = "gpumon" if shutil.which("nvidia-smi") else "gpuTemp"
    mons = ["cpuUsage", "cpuTemp", gpu, "memUsage", "diskmon"]
    # docker widget only where docker exists; hass stays unplaced until the
    # user adds its token (else it renders an unconfigured/empty widget)
    apps = ["claudeCodeUsage"]
    if shutil.which("docker") or shutil.which("podman"):
        apps.append("dockerManager")
    rw = ["netspeed"] + mons + apps + ["systemTray", "clipboard",
          "privacyIndicator", "idleInhibitor", "notificationButton",
          "systemUpdate"]
    if glob.glob("/sys/class/power_supply/BAT*"):
        rw.append("battery")
    rw.append("controlCenterButton")
    c["rightWidgets"] = rw
    print("bar widgets:", rw)
json.dump(d, open(p, "w"), indent=2)
EOF
setsid -f dms run >/dev/null 2>&1
echo "dms configured, shell restarted"
