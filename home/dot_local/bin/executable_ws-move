#!/usr/bin/env python3
# move current workspace to the next monitor by x position, wrapping at the
# edges like i3; skips headless outputs
import json, subprocess, sys

step = 1 if (sys.argv[1:] or ["r"])[0] == "r" else -1
out = subprocess.run(["hyprctl", "-j", "monitors"], capture_output=True, text=True).stdout
mons = [m for m in json.loads(out) if not m["name"].startswith("HEADLESS")]
if len(mons) < 2:
    sys.exit(0)
mons.sort(key=lambda m: m["x"])
cur = next(i for i, m in enumerate(mons) if m["focused"])
target = mons[(cur + step) % len(mons)]["name"]
subprocess.run(["hyprctl", "dispatch", "movecurrentworkspacetomonitor", target])
