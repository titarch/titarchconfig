# Deployed to /etc/X11/Xwrapper.config
# Allow starting the X server from a non-console session (SSH), so the
# `stream` script can bring up X on a headless/tty-only machine for
# Sunshine streaming ("stream on" over SSH after a reboot).
#
# needs_root_rights=yes: rootless X requires a logind seat/VT session,
# which an SSH session doesn't have — the wrapper must run Xorg as root
# (as any pre-rootless X setup did). This also applies to console startx.
allowed_users=anybody
needs_root_rights=yes
