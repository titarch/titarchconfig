[Trigger]
Operation = Install
Operation = Upgrade
Type = Package
Target = firefox

[Action]
Description = Reinstalling Firefox autoconfig (tab scroll fix)
When = PostTransaction
Exec = /bin/sh -c 'install -m644 /home/bparsy/titarchconfig/system/firefox/config.js /usr/lib/firefox/config.js; install -m644 /home/bparsy/titarchconfig/system/firefox/config-prefs.js /usr/lib/firefox/defaults/pref/config-prefs.js'
